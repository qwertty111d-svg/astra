---
export const prerender = false;

import "../styles/astra-dashboard.css";

const next = Astro.url.searchParams.get("next") || "/account";
const reset = Astro.url.searchParams.get("reset");
import MotionBackground from "../components/MotionBackground.astro";
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Вход в Astra</title>
  </head>

  <body>
    <MotionBackground />
    <div class="page-shell">
      <div class="orb orb-a"></div>
      <div class="orb orb-b"></div>
      <div class="orb orb-c"></div>

      <main class="download-screen">
        <section class="download-card glass">
          <p class="eyebrow" style="text-align:center;">astra auth</p>
          <h1 style="text-align:center;">Вход в аккаунт</h1>
          <p class="muted" style="text-align:center;">
            Войди в кабинет Astra для управления аккаунтом, устройствами и безопасностью.
          </p>

          {reset === "success" && (
            <p class="muted" style="margin-top:14px; text-align:center; color:#86efac;">
              Пароль обновлён. Теперь войди с новым паролем.
            </p>
          )}

          <div class="form-grid" style="margin-top: 22px;">
            <div class="field-full field">
              <label for="email">Email</label>
              <input id="email" type="email" placeholder="you@example.com" autocomplete="email" />
            </div>

            <div class="field-full field">
              <label for="password">Пароль</label>
              <input id="password" type="password" placeholder="Пароль" autocomplete="current-password" />
            </div>
          </div>

          <div class="actions-row" style="justify-content:space-between; margin-top:10px;">
            <a class="muted" href="/forgot-password" style="font-size:.95rem; text-decoration:none;">
              Забыл пароль?
            </a>
            <a class="muted" href="/register" style="font-size:.95rem; text-decoration:none;">
              Создать аккаунт
            </a>
          </div>

          <div class="center-actions" style="margin-top: 18px;">
            <button class="btn btn-primary" id="loginBtn" type="button">Войти</button>
            <a class="btn btn-secondary" href="/">На главную</a>
          </div>

          <p id="loginError" class="muted" style="margin-top:14px; text-align:center;"></p>
        </section>
      </main>
    </div>

    <script is:inline define:vars={{ next }}>
      const loginBtn = document.getElementById("loginBtn");
      const errorBox = document.getElementById("loginError");
      const emailInput = document.getElementById("email");
      const passwordInput = document.getElementById("password");

      async function submitLogin() {
        const email = emailInput?.value ?? "";
        const password = passwordInput?.value ?? "";

        errorBox.textContent = "";

        try {
          loginBtn.disabled = true;
          loginBtn.textContent = "Входим...";

          const response = await fetch("/api/auth/login", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ email, password, next }),
          });

          const data = await response.json().catch(() => ({}));

          if (!response.ok || !data.ok) {
            throw new Error(data.error || "Ошибка входа");
          }

          window.location.href = data.redirectTo || "/account";
        } catch (error) {
          errorBox.textContent = error.message || "Ошибка входа";
        } finally {
          loginBtn.disabled = false;
          loginBtn.textContent = "Войти";
        }
      }

      loginBtn?.addEventListener("click", submitLogin);

      [emailInput, passwordInput].forEach((input) => {
        input?.addEventListener("keydown", (event) => {
          if (event.key === "Enter") {
            event.preventDefault();
            submitLogin();
          }
        });
      });
    </script>
  </body>
</html>