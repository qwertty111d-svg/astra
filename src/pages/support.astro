---
import MotionBackground from "../components/MotionBackground.astro";
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Поддержка — Astra</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg-primary: #09090b;
      --bg-secondary: #111114;
      --bg-tertiary: #18181b;
      --bg-card: #141417;
      --border: #27272a;
      --border-hover: #3f3f46;
      --text-primary: #fafafa;
      --text-secondary: #a1a1aa;
      --text-tertiary: #71717a;
      --accent: #a78bfa;
      --accent-dim: #7c3aed;
      --accent-bg: rgba(167, 139, 250, 0.08);
      --accent-border: rgba(167, 139, 250, 0.18);
      --font-body: 'Outfit', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
      --nav-height: 64px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      font-family: var(--font-body);
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      height: var(--nav-height);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      background: rgba(9, 9, 11, 0.82);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: var(--font-mono);
      font-size: 1.05rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
    }

    .nav-logo .dot {
      width: 8px;
      height: 8px;
      background: var(--accent);
      border-radius: 50%;
      box-shadow: 0 0 12px rgba(167, 139, 250, 0.5);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }

    .nav-link {
      color: var(--text-secondary);
      font-size: 0.92rem;
      transition: color 0.2s ease;
    }

    .nav-link:hover {
      color: var(--text-primary);
    }

    .nav-cta {
      padding: 0.62rem 1rem;
      border-radius: 10px;
      background: var(--accent-dim);
      color: #fff;
      font-size: 0.86rem;
      font-weight: 600;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
      box-shadow: 0 8px 24px rgba(124, 58, 237, 0.22);
    }

    .nav-cta:hover {
      transform: translateY(-1px);
      background: var(--accent);
      box-shadow: 0 12px 30px rgba(124, 58, 237, 0.3);
    }

    .hero {
      position: relative;
      overflow: hidden;
      padding: 7rem 2rem 4rem;
      border-bottom: 1px solid var(--border);
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 15% 25%, rgba(167, 139, 250, 0.12) 0%, transparent 28%),
        radial-gradient(circle at 85% 15%, rgba(124, 58, 237, 0.1) 0%, transparent 24%);
      pointer-events: none;
    }

    .container {
      max-width: 1100px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.42rem 0.95rem;
      margin-bottom: 1.4rem;
      border-radius: 999px;
      border: 1px solid var(--accent-border);
      background: var(--accent-bg);
      color: var(--accent);
      font-size: 0.8rem;
      font-family: var(--font-mono);
    }

    .hero-badge::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 10px rgba(167, 139, 250, 0.6);
    }

    h1 {
      font-size: clamp(2.3rem, 5vw, 4.2rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
      margin-bottom: 1rem;
      max-width: 760px;
    }

    .gradient-text {
      background: linear-gradient(90deg, #8b5cf6 0%, #a78bfa 50%, #c4b5fd 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-desc {
      max-width: 720px;
      color: var(--text-secondary);
      font-size: 1.05rem;
      line-height: 1.75;
    }

    section {
      padding: 5rem 2rem;
    }

    .section-head {
      margin-bottom: 2rem;
    }

    .section-label {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 1rem;
    }

    .section-title {
      font-size: clamp(1.8rem, 4vw, 2.7rem);
      line-height: 1.12;
      letter-spacing: -0.03em;
      margin-bottom: 0.8rem;
    }

    .section-desc {
      max-width: 700px;
      color: var(--text-secondary);
      font-size: 1rem;
    }

    .support-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-top: 2rem;
    }

    .support-card {
      background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.01) 100%);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 1.6rem;
      transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
      box-shadow: 0 10px 30px rgba(0,0,0,0.18);
    }

    .support-card:hover {
      transform: translateY(-4px);
      border-color: rgba(167, 139, 250, 0.28);
      box-shadow: 0 16px 38px rgba(0,0,0,0.28), 0 0 30px rgba(124, 58, 237, 0.08);
    }

    .card-icon {
      width: 46px;
      height: 46px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      color: var(--accent);
      background: var(--accent-bg);
      border: 1px solid var(--accent-border);
    }

    .support-card h3 {
      font-size: 1.06rem;
      margin-bottom: 0.6rem;
    }

    .support-card p {
      color: var(--text-secondary);
      font-size: 0.94rem;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .support-card a {
      color: var(--accent);
      font-weight: 500;
    }

    .support-card a:hover {
      color: #c4b5fd;
    }

    .contact-box {
      margin-top: 2rem;
      padding: 1.6rem;
      border-radius: 24px;
      background:
        linear-gradient(180deg, rgba(167, 139, 250, 0.08) 0%, rgba(167, 139, 250, 0.03) 100%);
      border: 1px solid rgba(167, 139, 250, 0.16);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.04),
        0 14px 36px rgba(0,0,0,0.22);
    }

    .contact-box h3 {
      font-size: 1.1rem;
      margin-bottom: 0.6rem;
    }

    .contact-box p {
      color: var(--text-secondary);
      margin-bottom: 0.4rem;
    }

    .contact-box strong {
      color: var(--text-primary);
    }

    .faq-list {
      margin-top: 2rem;
      max-width: 860px;
    }

    .faq-item {
      border-bottom: 1px solid var(--border);
    }

    .faq-question {
      width: 100%;
      background: none;
      border: none;
      color: var(--text-primary);
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 500;
      text-align: left;
      padding: 1.35rem 0;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .faq-question:hover {
      color: var(--accent);
    }

    .faq-icon {
      color: var(--text-tertiary);
      font-size: 1.2rem;
      transition: transform 0.25s ease, color 0.25s ease;
      flex-shrink: 0;
    }

    .faq-item.active .faq-icon {
      transform: rotate(45deg);
      color: var(--accent);
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease, padding 0.3s ease;
    }

    .faq-item.active .faq-answer {
      max-height: 220px;
      padding-bottom: 1.25rem;
    }

    .faq-answer p {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.75;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin-top: 2rem;
    }

    .info-card {
      padding: 1.5rem;
      border-radius: 20px;
      background: var(--bg-card);
      border: 1px solid var(--border);
    }

    .info-card h3 {
      font-size: 1rem;
      margin-bottom: 0.6rem;
    }

    .info-card p,
    .info-card li {
      color: var(--text-secondary);
      font-size: 0.94rem;
      line-height: 1.7;
    }

    .info-card ul {
      padding-left: 1rem;
      margin-top: 0.5rem;
    }

    footer {
      border-top: 1px solid var(--border);
      padding: 2rem;
    }

    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .footer-left {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .footer-logo {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .footer-copy {
      color: var(--text-tertiary);
      font-size: 0.82rem;
    }

    .footer-links {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      list-style: none;
      flex-wrap: wrap;
    }

    .footer-links a {
      color: var(--text-tertiary);
      font-size: 0.82rem;
      transition: color 0.2s ease;
    }

    .footer-links a:hover {
      color: var(--text-secondary);
    }

    @media (max-width: 900px) {
      .support-grid,
      .info-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      nav {
        padding: 0 1rem;
      }

      .nav-actions {
        gap: 0.6rem;
      }

      .nav-link {
        display: none;
      }

      .hero,
      section,
      footer {
        padding-left: 1.2rem;
        padding-right: 1.2rem;
      }

      .footer-inner {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
    <MotionBackground />
  <nav>
    <a href="/" class="nav-logo">
      <span class="dot"></span>
      astra
    </a>

    <div class="nav-actions">
      <a href="/" class="nav-link">Главная</a>
      <a href="/login" class="nav-cta" id="navAuthBtn">LOG IN</a>
    </div>
  </nav>

  <section class="hero">
    <div class="container">
      <div class="hero-badge">Support Center</div>
      <h1>Поддержка <span class="gradient-text">Astra</span></h1>
      <p class="hero-desc">
        Если у тебя возникли проблемы с установкой, аккаунтом, подпиской или работой приложения,
        здесь собрана основная помощь. Если вопрос не решился, свяжись с нами напрямую.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
        <div class="section-label">Помощь</div>
        <h2 class="section-title">С чем мы помогаем</h2>
        <p class="section-desc">
          Ниже самые частые категории обращений. Выбирай нужное направление и пиши с деталями, чтобы решить вопрос быстрее.
        </p>
      </div>

      <div class="support-grid">
        <div class="support-card">
          <div class="card-icon">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
              <path d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4z" />
              <path d="M9.5 12l1.7 1.7L14.8 10" />
            </svg>
          </div>
          <h3>Аккаунт и вход</h3>
          <p>Помощь с регистрацией, входом в аккаунт, восстановлением доступа и проблемами авторизации.</p>
          <a href="mailto:support@astra-app.ru">support@astra-app.ru</a>
        </div>

        <div class="support-card">
          <div class="card-icon">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="M3 10h18" />
            </svg>
          </div>
          <h3>Подписка и оплата</h3>
          <p>Вопросы по тарифам Free, Pro, Lifetime, оплатам, отмене подписки и доступу к функциям.</p>
          <a href="mailto:billing@astra-app.ru">billing@astra-app.ru</a>
        </div>

        <div class="support-card">
          <div class="card-icon">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
              <path d="M12 2v4" />
              <path d="M12 18v4" />
              <path d="M4.93 4.93l2.83 2.83" />
              <path d="M16.24 16.24l2.83 2.83" />
              <path d="M2 12h4" />
              <path d="M18 12h4" />
              <path d="M4.93 19.07l2.83-2.83" />
              <path d="M16.24 7.76l2.83-2.83" />
              <circle cx="12" cy="12" r="3" />
            </svg>
          </div>
          <h3>Технические проблемы</h3>
          <p>Ошибки запуска, проблемы с производительностью, диагностикой, оптимизацией и совместимостью.</p>
          <a href="mailto:tech@astra-app.ru">tech@astra-app.ru</a>
        </div>
      </div>

      <div class="contact-box">
        <h3>Основной канал связи</h3>
        <p><strong>Email поддержки:</strong> support@astra-app.ru</p>
        <p><strong>Время ответа:</strong> обычно в течение 24-48 часов</p>
        <p><strong>Что лучше сразу указать:</strong> версию Windows, описание проблемы, скриншот ошибки, тариф и почту аккаунта</p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
        <div class="section-label">FAQ</div>
        <h2 class="section-title">Частые вопросы</h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('active')">
            Astra не запускается после установки
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Проверь, что у тебя Windows 10 или 11, приложение скачано с официального сайта, а антивирус не заблокировал запуск файла. Если проблема остаётся, отправь в поддержку скрин ошибки и версию системы.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('active')">
            Я оплатил тариф, но функции не открылись
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Сначала выйди из аккаунта и войди заново, затем проверь статус подписки в личном кабинете. Если доступ не активировался, напиши в поддержку с почтой аккаунта и подтверждением оплаты.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('active')">
            Как отменить подписку?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Подписку можно отключить в личном кабинете. После отмены доступ к платным функциям сохраняется до конца уже оплаченного периода, если иное не указано в условиях тарифа.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('active')">
            Astra безопасна для системы?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>Astra предназначена для оптимизации системы и не должна использоваться как средство обхода ограничений, взлома или вмешательства в работу стороннего ПО. Перед серьёзными изменениями рекомендуется сохранить важные данные.</p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="this.parentElement.classList.toggle('active')">
            Куда писать по возврату?
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>По вопросам возврата и спорным списаниям пиши на billing@astra-app.ru. В письме укажи дату оплаты, сумму, почту аккаунта и коротко опиши причину обращения.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-head">
        <div class="section-label">Перед обращением</div>
        <h2 class="section-title">Что лучше подготовить заранее</h2>
        <p class="section-desc">
          Чем точнее данные, тем быстрее можно понять, где косяк. Поддержка не любит гадать на цифровой гуще.
        </p>
      </div>

      <div class="info-grid">
        <div class="info-card">
          <h3>Для технической проблемы</h3>
          <ul>
            <li>версия Windows</li>
            <li>когда именно появилась ошибка</li>
            <li>скриншот или текст ошибки</li>
            <li>какая версия Astra установлена</li>
          </ul>
        </div>

        <div class="info-card">
          <h3>Для вопросов по оплате</h3>
          <ul>
            <li>почта аккаунта</li>
            <li>дата и сумма оплаты</li>
            <li>название тарифа</li>
            <li>номер заказа или чек, если есть</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="footer-inner">
      <div class="footer-left">
        <a href="/" class="footer-logo">
          <span style="width:6px;height:6px;background:var(--accent);border-radius:50%;display:inline-block;box-shadow:0 0 8px rgba(167,139,250,0.4)"></span>
          astra
        </a>
        <span class="footer-copy">© 2026 Astra. Все права защищены.</span>
      </div>

      <ul class="footer-links">
        <li><a href="/privacy">Политика конфиденциальности</a></li>
        <li><a href="/terms">Условия использования</a></li>
        <li><a href="/support">Поддержка</a></li>
      </ul>
    </div>
  </footer>

  <script>
  (async () => {
    const navAuthBtn = document.getElementById('navAuthBtn');

    try {
      const res = await fetch('/api/auth/session', {
        credentials: 'same-origin',
      });

      const data = await res.json();

      if (data?.authenticated && navAuthBtn) {
        navAuthBtn.textContent = 'КАБИНЕТ';
        navAuthBtn.setAttribute('href', '/account');
      }
    } catch {}
  })();
</script>
  </script>
</body>
</html>