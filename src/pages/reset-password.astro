---
export const prerender = false;
import "../styles/astra-auth.css";
const token = Astro.url.searchParams.get("token") || "";
const turnstileSiteKey = "";
---
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Новый пароль — Astra</title>
    
  </head>
  <body data-token={token}>
    <div class="auth-bg-fx" aria-hidden="true"></div>
    <a href="/" class="auth-back" aria-label="Вернуться на главную страницу">
      <span>←</span>
      <span class="auth-back__brand">ASTRA</span>
    </a>

    <div class="auth-shell">
      <div class="grid-noise"></div>
      <div class="orb orb-a"></div>
      <div class="orb orb-b"></div>
      <div class="orb orb-c"></div>
      
<section class="auth-card">
  <div class="auth-brand"><span class="auth-dot"></span><span>astra</span></div>
  <p class="eyebrow">astra recovery</p>
  <h1 class="auth-title">Новый пароль</h1>
  <p class="auth-copy">Задай новый пароль для аккаунта и верни контроль над входом.</p>
  <div class="auth-form">
    <div class="field">
      <label for="newPassword">Новый пароль</label>
      <div class="input-wrap">
        <input class="input input--with-action" id="newPassword" type="password" placeholder="Минимум 8 символов" autocomplete="new-password" />
        <button class="input-action" id="toggleNew" type="button">◐</button>
      </div>
    </div>
    <div class="field">
      <label for="repeatPassword">Повтори пароль</label>
      <div class="input-wrap">
        <input class="input input--with-action" id="repeatPassword" type="password" placeholder="Повтори новый пароль" autocomplete="new-password" />
        <button class="input-action" id="toggleRepeat" type="button">◐</button>
      </div>
    </div>
    <div class="auth-actions">
      <button class="btn btn-primary" id="saveBtn" type="button">Сохранить пароль</button>
      <a class="btn btn-secondary" href="/login">К входу</a>
    </div>
    <p id="status" class="status"></p>
  </div>
</section>

    </div>

    <script is:inline>

      const qs = (selector) => document.querySelector(selector);
      const qsa = (selector) => Array.from(document.querySelectorAll(selector));

      function attachPasswordToggle(buttonId, inputId) {
        const button = document.getElementById(buttonId);
        const input = document.getElementById(inputId);
        if (!(button instanceof HTMLElement) || !(input instanceof HTMLInputElement)) return;
        button.addEventListener("click", () => {
          const hidden = input.type === "password";
          input.type = hidden ? "text" : "password";
          button.textContent = hidden ? "✕" : "◐";
        });
      }

      function attachCodeInputs(selector) {
        const inputs = qsa(selector);
        inputs.forEach((input, index) => {
          input.addEventListener("input", () => {
            input.value = input.value.replace(/\D/g, "").slice(-1);
            if (input.value && inputs[index + 1]) inputs[index + 1].focus();
          });
          input.addEventListener("keydown", (event) => {
            if (event.key === "Backspace" && !input.value && inputs[index - 1]) inputs[index - 1].focus();
            if (event.key === "ArrowLeft" && inputs[index - 1]) inputs[index - 1].focus();
            if (event.key === "ArrowRight" && inputs[index + 1]) inputs[index + 1].focus();
          });
          input.addEventListener("paste", (event) => {
            const pasted = (event.clipboardData?.getData("text") || "").replace(/\D/g, "").slice(0, inputs.length);
            if (!pasted) return;
            event.preventDefault();
            pasted.split("").forEach((char, i) => { if (inputs[i]) inputs[i].value = char; });
            inputs[Math.min(pasted.length - 1, inputs.length - 1)]?.focus();
          });
        });
        return () => inputs.map((input) => input.value).join("");
      }

      window.onLoginTurnstileSuccess = (token) => {
        window.__astraLoginTurnstile = token;
      };

      window.onLoginTurnstileExpired = () => {
        window.__astraLoginTurnstile = "";
      };

      window.onRegisterTurnstileSuccess = (token) => {
        window.__astraRegisterTurnstile = token;
      };

      window.onRegisterTurnstileExpired = () => {
        window.__astraRegisterTurnstile = "";
      };

    </script>
    
<script is:inline>
(() => {
  attachPasswordToggle("toggleNew", "newPassword");
  attachPasswordToggle("toggleRepeat", "repeatPassword");
  const token = document.body.dataset.token || "";
  const saveBtn = document.getElementById("saveBtn");
  const status = document.getElementById("status");
  const newPasswordInput = document.getElementById("newPassword");
  const repeatPasswordInput = document.getElementById("repeatPassword");

  async function submitNewPassword() {
    const newPassword = newPasswordInput?.value ?? "";
    const repeatPassword = repeatPasswordInput?.value ?? "";
    status.textContent = "";
    if (!token) { status.textContent = "Токен сброса отсутствует."; return; }
    if (!newPassword || !repeatPassword) { status.textContent = "Заполни оба поля."; return; }
    if (newPassword !== repeatPassword) { status.textContent = "Пароли не совпадают."; return; }
    try {
      saveBtn.disabled = true;
      saveBtn.textContent = "Сохраняем...";
      const response = await fetch("/api/auth/reset-password", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ token, newPassword }) });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || !data.ok) throw new Error(data.error || "Не удалось обновить пароль.");
      status.textContent = data.message || "Пароль обновлён.";
      status.className = "status success";
      setTimeout(() => { window.location.href = data.redirectTo || "/login"; }, 900);
    } catch (error) {
      status.textContent = error?.message || "Ошибка запроса.";
      status.className = "status";
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = "Сохранить пароль";
    }
  }

  saveBtn?.addEventListener("click", submitNewPassword);
  [newPasswordInput, repeatPasswordInput].forEach((input) => input?.addEventListener("keydown", (event) => { if (event.key === "Enter") { event.preventDefault(); submitNewPassword(); }}));
})();
</script>

  </body>
</html>
