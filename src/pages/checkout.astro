---
export const prerender = false;

import "../styles/astra-members.css";
import { getPaymentRequestsForUser, getPlanConfig, normalizePlan, isAdminEmail } from "../lib/server/payments.js";
import { readEnv } from "../lib/server/env.js";
import AccountTopBar from "../components/AccountTopBar.astro";

const currentUser = Astro.locals.user;
const plan = normalizePlan(Astro.url.searchParams.get("plan") || "PRO");
const planConfig = getPlanConfig(plan);

if (!currentUser) {
  return Astro.redirect(`/login?next=${encodeURIComponent(`/checkout?plan=${plan.toLowerCase()}`)}`);
}

const requests = await getPaymentRequestsForUser(currentUser.id);
const isAdmin = isAdminEmail(currentUser.email);
const qrImage = readEnv("PUBLIC_TBANK_QR_IMAGE", "/payment-icons/sbp.png");
const paymentInstructions = readEnv(
  "PUBLIC_PAYMENT_INSTRUCTIONS",
  "Оплати тариф по QR-коду Т-Банка. После оплаты нажми кнопку ниже и укажи время перевода, сумму и последние 4 цифры счёта."
);
const supportContact = readEnv("PUBLIC_PAYMENT_SUPPORT_CONTACT", "@astraboost_support");

function formatDateTime(value: string | null | undefined) {
  if (!value) return "—";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return "—";
  return new Intl.DateTimeFormat("ru-RU", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  }).format(date);
}

function getStatusLabel(status: string) {
  if (status === "approved") return "Подтверждено";
  if (status === "rejected") return "Отклонено";
  return "На проверке";
}
import MotionBackground from "../components/MotionBackground.astro";
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Astra • Оплата</title>
    <meta name="description" content="Оплата тарифа Astra через Т-Банк QR." />
  </head>
  <body class="page-transition page-ready">
    <MotionBackground />
    <div class="page-shell">
      <div class="bg-glow glow-left"></div>
      <div class="bg-glow glow-right"></div>

      <AccountTopBar current="checkout" isAdmin={isAdmin} actionHref="/account" actionLabel="В кабинет" />

      <main class="page">
        <section class="pricing-hero">
          <article class="panel checkout-copy-panel">
            <div class="panel-inner pricing-hero-copy">
              <p class="eyebrow">оплата</p>
              <h1 class="title-xl">{planConfig.label} за {planConfig.amountRub}₽</h1>
              <p class="muted hero-copy-text">{planConfig.description} {paymentInstructions}</p>

              <div class="hero-pills hero-pills--compact">
                <span class="pill">{currentUser.email}</span>
                <span class="pill">{plan === "LIFETIME" ? "единоразово" : "в месяц"}</span>
              </div>

              <div class="hero-pills">
                <span class="pill">Т-Банк</span>
                <span class="pill">QR-код</span>
                <span class="pill">Проверка админом</span>
              </div>
            </div>
          </article>

          <article class="panel compare-hero-panel checkout-qr-surface">
            <div class="panel-inner checkout-qr-panel">
              <p class="eyebrow">qr</p>
              <img src={qrImage} alt="QR для оплаты" class="checkout-qr-image" />
              <div class="checkout-meta-grid">
                <div class="checkout-meta-card">
                  <span>Тариф</span>
                  <strong>{planConfig.label}</strong>
                </div>
                <div class="checkout-meta-card">
                  <span>Сумма</span>
                  <strong>{planConfig.amountRub}₽</strong>
                </div>
                <div class="checkout-meta-card checkout-meta-card--wide">
                  <span>Аккаунт</span>
                  <strong>{currentUser.email}</strong>
                </div>
                <div class="checkout-meta-card checkout-meta-card--wide">
                  <span>Контакт для вопросов</span>
                  <strong>{supportContact}</strong>
                </div>
              </div>
            </div>
          </article>
        </section>

        <section class="account-grid">
          <article class="panel checkout-request-panel">
            <div class="panel-inner" style="display:grid;gap:16px;">
              <div class="section-head">
                <p class="eyebrow">шаг 1</p>
                <h2 class="title-lg">После оплаты отправь заявку</h2>
              </div>

              <label class="field" style="display:grid;gap:10px;">
                <span class="muted">Комментарий к заявке</span>
                <textarea id="payerNote" class="input" rows="4" placeholder="Например: оплатил в 14:32, сумма 599₽, последние 4 цифры счёта 4821"></textarea>
              </label>

              <div class="hero-actions">
                <button id="submitPaymentRequest" class="btn btn-primary">Я оплатил</button>
                <a href="/pricing" class="btn btn-secondary">Назад к тарифам</a>
              </div>

              <p id="paymentStatus" class="status"></p>
            </div>
          </article>

          <article class="panel checkout-history-panel">
            <div class="panel-inner" style="display:grid;gap:16px;">
              <div class="section-head">
                <p class="eyebrow">история</p>
                <h2 class="title-lg">Твои заявки</h2>
              </div>

              <div class="payment-history-list">
                {requests.length ? requests.map((request) => (
                  <div class="summary-card payment-history-card">
                    <div class="payment-history-head">
                      <div>
                        <strong>{request.plan}</strong>
                        <span class="muted">{request.amountRub}₽ • Создано: {formatDateTime(request.createdAt)}</span>
                      </div>
                      <span class={`pill ${request.status === "approved" ? "good" : request.status === "rejected" ? "expired" : "mid"}`}>{getStatusLabel(request.status)}</span>
                    </div>

                    <div class="payment-chat">
                      {request.payerNote && (
                        <div class="payment-bubble payment-bubble-user">
                          <span class="payment-bubble-role">Твой комментарий</span>
                          <strong>{request.payerNote}</strong>
                        </div>
                      )}

                      {request.adminNote && (
                        <div class={`payment-bubble payment-bubble-admin ${request.status === "rejected" ? "is-reject" : ""}`}>
                          <span class="payment-bubble-role">Ответ администратора</span>
                          <strong>{request.adminNote}</strong>
                          {(request.reviewedBy || request.reviewedAt) && (
                            <small>
                              {request.reviewedBy ? `Админ: ${request.reviewedBy}` : ""}
                              {request.reviewedBy && request.reviewedAt ? " • " : ""}
                              {request.reviewedAt ? formatDateTime(request.reviewedAt) : ""}
                            </small>
                          )}
                        </div>
                      )}

                      {!request.adminNote && request.status === "pending" && (
                        <div class="payment-bubble payment-bubble-pending">
                          <span class="payment-bubble-role">Статус</span>
                          <strong>Заявка отправлена. Жди проверку администратора.</strong>
                        </div>
                      )}
                    </div>
                  </div>
                )) : <div class="summary-card"><span class="muted">Заявок пока нет.</span></div>}
              </div>
            </div>
          </article>
        </section>
      </main>
    </div>

    <script is:inline define:vars={{ plan }}>
      const submitButton = document.getElementById("submitPaymentRequest");
      const payerNote = document.getElementById("payerNote");
      const paymentStatus = document.getElementById("paymentStatus");

      function setStatus(text, type = "") {
        if (!paymentStatus) return;
        paymentStatus.textContent = text;
        paymentStatus.className = `status ${type}`.trim();
      }

      const autoGrowNote = (textarea) => {
        if (!textarea) return;
        textarea.style.height = "0px";
        textarea.style.height = `${Math.max(textarea.scrollHeight, 112)}px`;
      };

      autoGrowNote(payerNote);
      payerNote?.addEventListener("input", () => autoGrowNote(payerNote));

      submitButton?.addEventListener("click", async () => {
        try {
          submitButton.disabled = true;
          submitButton.textContent = "Создаём заявку...";
          setStatus("");

          const response = await fetch("/api/payments/request", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              plan,
              payerNote: payerNote?.value || "",
            }),
          });

          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.ok) throw new Error(data.error || "Не удалось создать заявку.");

          setStatus(data.message || "Заявка создана.", "success");
          window.setTimeout(() => window.location.reload(), 900);
        } catch (error) {
          setStatus(error?.message || "Ошибка.");
        } finally {
          submitButton.disabled = false;
          submitButton.textContent = "Я оплатил";
        }
      });
    </script>
  </body>
</html>

<style is:inline>
  .checkout-copy-panel,
  .checkout-qr-surface,
  .checkout-request-panel,
  .checkout-history-panel {
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .checkout-copy-panel .pricing-hero-copy {
    gap: 14px;
  }

  .checkout-qr-surface .checkout-qr-panel {
    gap: 20px;
  }

  .checkout-request-panel .panel-inner,
  .checkout-history-panel .panel-inner {
    position: relative;
  }

  .checkout-request-panel .panel-inner::after,
  .checkout-history-panel .panel-inner::after {
    content: "";
    position: absolute;
    inset: auto -20px -20px auto;
    width: 160px;
    height: 160px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(140, 104, 255, 0.12), transparent 72%);
    pointer-events: none;
  }
</style>
