    align-items: stretch;
  }

  .cookie-btn {
    width: 100%;
    justify-content: center;
  }

  .cookie-modal__dialog {
    padding: 1rem;
    border-radius: 18px;
  }

  .cookie-option {
    grid-template-columns: 1fr;
    align-items: start;
  }

  .cookie-modal__actions {
    flex-direction: column;
  }

  .cookie-modal__actions .cookie-btn {
    width: 100%;
  }

  .cookie-toast {
    left: 12px;
    right: 12px;
    bottom: 12px;
  }
}

