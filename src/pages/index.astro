      gap: 0.75rem;
    }
  }
  /* ── FLOATING ORBS + MOUSE PARALLAX ── */
.hero-glass {
  will-change: transform;
  --mx: 0px;
  --my: 0px;
}

.hero-glass-1 {
  animation: floatGlass1 18s ease-in-out infinite;
  animation-delay: 0s;
}

.hero-glass-2 {
  animation: floatGlass2 22s ease-in-out infinite;
  animation-delay: -4s;
}

.hero-glass-3 {
  animation: floatGlass3 16s ease-in-out infinite;
  animation-delay: -2s;
}

@keyframes floatGlass1 {
  0% {
    transform: translate3d(calc(0px + var(--mx)), calc(0px + var(--my)), 0) rotate(0deg) scale(1);
  }
  25% {
    transform: translate3d(calc(-10px + var(--mx)), calc(12px + var(--my)), 0) rotate(1deg) scale(1.015);
  }
  50% {
    transform: translate3d(calc(-22px + var(--mx)), calc(26px + var(--my)), 0) rotate(0deg) scale(0.99);
  }
  75% {
    transform: translate3d(calc(-8px + var(--mx)), calc(10px + var(--my)), 0) rotate(-1deg) scale(1.01);
  }
  100% {
    transform: translate3d(calc(0px + var(--mx)), calc(0px + var(--my)), 0) rotate(0deg) scale(1);
  }
}

@keyframes floatGlass2 {
  0% {
    transform: translate3d(calc(0px + var(--mx)), calc(0px + var(--my)), 0) rotate(0deg) scale(1);
  }
  25% {
    transform: translate3d(calc(12px + var(--mx)), calc(-10px + var(--my)), 0) rotate(-1deg) scale(1.01);
  }
  50% {
    transform: translate3d(calc(24px + var(--mx)), calc(-20px + var(--my)), 0) rotate(0deg) scale(0.985);
  }
  75% {
    transform: translate3d(calc(10px + var(--mx)), calc(-8px + var(--my)), 0) rotate(1deg) scale(1.01);
  }
  100% {
    transform: translate3d(calc(0px + var(--mx)), calc(0px + var(--my)), 0) rotate(0deg) scale(1);
  }
}

@keyframes floatGlass3 {
  0% {
    transform: translateY(-50%) translate3d(calc(0px + var(--mx)), calc(0px + var(--my)), 0) scale(1);
  }
  25% {
    transform: translateY(-50%) translate3d(calc(8px + var(--mx)), calc(-10px + var(--my)), 0) scale(1.02);
  }
  50% {
    transform: translateY(-50%) translate3d(calc(18px + var(--mx)), calc(-18px + var(--my)), 0) scale(0.98);
  }
  75% {
    transform: translateY(-50%) translate3d(calc(6px + var(--mx)), calc(-8px + var(--my)), 0) scale(1.01);
  }
  100% {
    transform: translateY(-50%) translate3d(calc(0px + var(--mx)), calc(0px + var(--my)), 0) scale(1);
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-glass-1,
  .hero-glass-2,
  .hero-glass-3 {
    animation: none;
    --mx: 0px !important;
    --my: 0px !important;
  }
}

