---
import MotionBackground from "../components/MotionBackground.astro";
---

<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Astra — Оптимизация сети и системы</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<style>
  :root {
    --bg-primary: #09090b;
    --bg-secondary: #111114;
    --bg-tertiary: #18181b;
    --bg-card: #141417;
    --border: #27272a;
    --border-hover: #3f3f46;
    --text-primary: #fafafa;
    --text-secondary: #a1a1aa;
    --text-tertiary: #71717a;
    --accent: #a78bfa;
    --accent-dim: #7c3aed;
    --accent-bg: rgba(167, 139, 250, 0.08);
    --accent-border: rgba(167, 139, 250, 0.15);
    --font-body: 'Outfit', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    --nav-height: 64px;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 84px;
    font-size: 16px;
  }

  body {
    font-family: var(--font-body);
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 2rem;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(9, 9, 11, 0.82);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .nav-logo:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  
  .nav-logo:hover .cat-logo {
    transform: translateY(-1px) scale(1.08) rotate(-3deg);
    filter: drop-shadow(0 0 12px rgba(124, 58, 237, 0.28));
  }
.nav-logo .cat-logo {
    width: 26px;
    height: 26px;
    display: inline-block;
    object-fit: contain;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    filter: drop-shadow(0 0 8px rgba(124, 58, 237, 0.18));
    transform-origin: center;
    transition: transform 180ms ease, filter 180ms ease;
  }

  .nav-links-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.nav-links {
  position: relative;
  display: flex;
  align-items: center;
  gap: 0.2rem;
  list-style: none;
  padding: 0.25rem;
  border-radius: 14px;
}

  .nav-links li {
    position: relative;
    z-index: 2;
    display: flex;
  }

  .nav-indicator {
  position: absolute;
  top: 0;
  left: 0;
  width: 0;
  height: 0;
  border-radius: 12px;
  background: rgba(167, 139, 250, 0.08);
  box-shadow:
    inset 0 0 0 1px rgba(167, 139, 250, 0.14),
    0 8px 28px rgba(0, 0, 0, 0.18);
  pointer-events: none;
  z-index: 1;
  opacity: 0;
  list-style: none;
  margin: 0;
  padding: 0;
  transition:
    left 0.38s cubic-bezier(0.22, 1, 0.36, 1),
    top 0.38s cubic-bezier(0.22, 1, 0.36, 1),
    width 0.38s cubic-bezier(0.22, 1, 0.36, 1),
    height 0.38s cubic-bezier(0.22, 1, 0.36, 1),
    opacity 0.22s ease;
}

.nav-indicator::after {
  display: none;
}

  .nav-links a {
    position: relative;
    z-index: 2;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.93rem;
    font-weight: 400;
    transition: color 0.25s ease, transform 0.2s ease;
  }

  .nav-links a:not(.nav-cta) {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 40px;
  padding: 0 1rem;
  border-radius: 12px;
  white-space: nowrap;
  line-height: 1;
}

.nav-links a:not(.nav-cta):hover {
  color: var(--text-primary);
}

  .nav-links a.active:not(.nav-cta) {
    color: var(--text-primary);
  }

  .nav-cta {
    padding: 0.5rem 1.25rem;
    background: var(--accent-dim);
    color: #fff !important;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.85rem !important;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .nav-cta:hover {
    background: var(--accent) !important;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(124, 58, 237, 0.25);
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    padding: 0.5rem;
  }


  .mobile-nav-backdrop {
    display: none;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 2rem 6rem;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 12% 85%, rgba(255,255,255,0.025) 0%, transparent 22%),
    radial-gradient(circle at 88% 12%, rgba(255,255,255,0.02) 0%, transparent 20%);
  pointer-events: none;
  z-index: 0;
}

.hero > *:not(.hero-glass) {
  position: relative;
  z-index: 2;
}

.hero-glass {
  position: absolute;
  border-radius: 999px;
  pointer-events: none;
  z-index: 0;
  background:
    linear-gradient(145deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 28%, rgba(255,255,255,0.005) 55%, rgba(0,0,0,0.14) 100%);
  border: 1px solid rgba(255,255,255,0.08);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-shadow:
    inset 1px 1px 0 rgba(255,255,255,0.18),
    inset -24px -24px 60px rgba(0,0,0,0.2),
    0 30px 80px rgba(0,0,0,0.45);
  opacity: 0.95;
}

.hero-glass::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background:
    radial-gradient(circle at 22% 18%, rgba(255,255,255,0.22) 0%, rgba(255,255,255,0.08) 18%, transparent 42%),
    linear-gradient(135deg, rgba(255,255,255,0.16) 0%, transparent 38%);
  mix-blend-mode: screen;
  opacity: 0.55;
}

.hero-glass::after {
  content: '';
  position: absolute;
  inset: 1.5%;
  border-radius: inherit;
  border: 1px solid rgba(255,255,255,0.08);
  mask-image: linear-gradient(to bottom right, rgba(0,0,0,1), transparent 70%);
  -webkit-mask-image: linear-gradient(to bottom right, rgba(0,0,0,1), transparent 70%);
  opacity: 0.8;
}

.hero-glass-1 {
  width: 520px;
  height: 520px;
  top: -240px;
  right: -180px;
}

.hero-glass-2 {
  width: 460px;
  height: 460px;
  bottom: -220px;
  left: -140px;
}

.hero-glass-3 {
  width: 240px;
  height: 240px;
  top: 52%;
  right: 12%;
  transform: translateY(-50%);
  opacity: 0.45;
  filter: blur(1px);
}

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border: 1px solid var(--accent-border);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 2rem;
    background: var(--accent-bg);
    font-family: var(--font-mono);
    animation: fadeUp 0.8s ease both;
  }

  .hero-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .hero h1 {
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    max-width: 800px;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.8s 0.1s ease both;
    text-shadow: 0 2px 18px rgba(255, 255, 255, 0.06);
  }

  .hero h1 .gradient-text {
  background: linear-gradient(
    90deg,
    #8b5cf6 0%,
    #a78bfa 25%,
    #c4b5fd 50%,
    #a78bfa 75%,
    #8b5cf6 100%
  );
  background-size: 300% 100%;
  background-position: 0% 50%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientFlow 8s ease-in-out infinite;
  filter:
    drop-shadow(0 0 10px rgba(167, 139, 250, 0.22))
    drop-shadow(0 0 24px rgba(124, 58, 237, 0.14));
}

  .hero p {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 540px;
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.8s 0.2s ease both;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    animation: fadeUp 0.8s 0.3s ease both;
  }

  .btn-primary {
  padding: 1rem 2.4rem;
  min-height: 58px;
  background: linear-gradient(135deg, #7c3aed 0%, #8b5cf6 55%, #a78bfa 100%);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 15px;
  font-size: 1.08rem;
  font-weight: 700;
  letter-spacing: -0.025em;
  line-height: 1;
  cursor: pointer;
  text-decoration: none;
  font-family: var(--font-body);
  transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 10px 28px rgba(124, 58, 237, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.16);
  text-shadow: 0 1px 8px rgba(0, 0, 0, 0.14);
}

.btn-primary:hover {
  transform: translateY(-2px);
  background: linear-gradient(135deg, #8b5cf6 0%, #9a6bff 55%, #b79cff 100%);
  box-shadow:
    0 16px 36px rgba(124, 58, 237, 0.38),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

  .btn-secondary {
    padding: 0.75rem 2rem;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 400;
    cursor: pointer;
    text-decoration: none;
    font-family: var(--font-body);
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }

  .hero-chips {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.75rem;
  margin-top: 2.25rem;
  animation: fadeUp 0.8s 0.35s ease both;
}

.hero-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.55rem;
  padding: 0.78rem 1rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-secondary);
  font-size: 0.88rem;
  font-weight: 400;
  line-height: 1;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.04),
    0 8px 24px rgba(0,0,0,0.18);
}

.hero-chip::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 10px rgba(167, 139, 250, 0.5);
  flex-shrink: 0;
}

  /* ── SECTIONS ── */
  section {
    padding: 7rem 2rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .section-title {
  font-size: clamp(2rem, 4vw, 2.75rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.15;
  margin-bottom: 1rem;
  text-shadow:
    0 0 12px rgba(255, 255, 255, 0.1),
    0 0 28px rgba(255, 255, 255, 0.07);
}

  .section-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 560px;
    font-weight: 300;
    line-height: 1.7;
  }

  /* ── FEATURES ── */
  .features {
    border-top: 1px solid var(--border);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 4rem;
    background: none;
    border: none;
    overflow: visible;
  }

  .feature-card {
    position: relative;
    min-height: 258px;
    padding: 2rem 1.95rem;
    border-radius: 28px;
    border: 1px solid rgba(167, 139, 250, 0.075);
    background:
      linear-gradient(180deg, rgba(13, 15, 28, 0.3) 0%, rgba(8, 9, 18, 0.16) 100%);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.025),
      0 14px 34px rgba(0, 0, 0, 0.12);
    transition:
      transform 0.24s ease,
      border-color 0.24s ease,
      background 0.24s ease,
      box-shadow 0.24s ease;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(circle at 14% 0%, rgba(167, 139, 250, 0.09), transparent 30%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.05), transparent 24%, transparent 76%, rgba(167, 139, 250, 0.05));
    opacity: 0.7;
    pointer-events: none;
  }

  .feature-card:hover {
    background:
      linear-gradient(180deg, rgba(16, 18, 34, 0.38) 0%, rgba(8, 10, 20, 0.22) 100%);
    border-color: rgba(167, 139, 250, 0.14);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 20px 42px rgba(0, 0, 0, 0.16),
      0 0 24px rgba(124, 58, 237, 0.08);
  }

  .feature-icon {
    position: relative;
    z-index: 1;
    width: 46px;
    height: 46px;
    border: 1px solid rgba(167, 139, 250, 0.13);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.35rem;
    background: linear-gradient(180deg, rgba(35, 28, 63, 0.22), rgba(11, 13, 25, 0.2));
    color: #bfa8ff;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.04),
      0 10px 24px rgba(0, 0, 0, 0.12);
    font-size: 1.2rem;
  }

  .feature-card h3 {
    position: relative;
    z-index: 1;
    font-size: 1.12rem;
    font-weight: 600;
    margin-bottom: 0.85rem;
    letter-spacing: -0.015em;
  }

  .feature-card p {
    position: relative;
    z-index: 1;
    font-size: 0.95rem;
    color: rgba(223, 227, 244, 0.72);
    line-height: 1.72;
    font-weight: 300;
    max-width: 28ch;
  }

  /* ── HOW IT WORKS ── */
  .how-it-works {
    border-top: 1px solid var(--border);
  }

  .steps {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    position: relative;
  }

  .steps::before {
    content: '';
    position: absolute;
    left: 58px;
    top: 1.25rem;
    bottom: 1.25rem;
    width: 1px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(167, 139, 250, 0.08) 10%,
      rgba(255, 255, 255, 0.06) 50%,
      rgba(167, 139, 250, 0.08) 90%,
      transparent 100%
    );
    opacity: 0.6;
    pointer-events: none;
  }

  .step {
    position: relative;
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 1.65rem;
    padding: 1.2rem 1.35rem;
    border: 1px solid rgba(167, 139, 250, 0.055);
    border-radius: 26px;
    background:
      linear-gradient(180deg, rgba(13, 14, 27, 0.28) 0%, rgba(7, 8, 18, 0.14) 100%);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    align-items: center;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.6s ease forwards;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.016),
      0 14px 34px rgba(0,0,0,0.09);
    transition:
      border-color 0.28s ease,
      box-shadow 0.28s ease,
      background 0.28s ease,
      transform 0.28s ease;
  }

  .step::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(circle at 0% 50%, rgba(167, 139, 250, 0.05) 0%, transparent 24%),
      linear-gradient(90deg, rgba(167,139,250,0.024) 0%, transparent 24%);
    pointer-events: none;
    opacity: 0.72;
  }

  .step::after {
    content: '';
    position: absolute;
    left: 58px;
    top: 50%;
    width: 22px;
    height: 1px;
    background: linear-gradient(90deg, rgba(167, 139, 250, 0.18), rgba(255, 255, 255, 0.05));
    transform: translateY(-50%);
    pointer-events: none;
  }

  .step:hover {
    transform: translateY(-2px);
    border-color: rgba(167, 139, 250, 0.1);
    background:
      linear-gradient(180deg, rgba(15, 16, 30, 0.32) 0%, rgba(8, 10, 20, 0.18) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.022),
      0 18px 38px rgba(0,0,0,0.12),
      0 0 24px rgba(124, 58, 237, 0.05);
  }

  .step:nth-child(1) { animation-delay: 0.1s; }
  .step:nth-child(2) { animation-delay: 0.2s; }
  .step:nth-child(3) { animation-delay: 0.3s; }
  .step:nth-child(4) { animation-delay: 0.4s; }

  .step-num {
    position: relative;
    z-index: 1;
    width: 76px;
    height: 76px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.34rem;
    padding: 0.85rem;
    border-radius: 22px;
    border: 1px solid rgba(167, 139, 250, 0.095);
    background:
      linear-gradient(180deg, rgba(36, 29, 66, 0.16) 0%, rgba(10, 11, 24, 0.2) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.025),
      0 10px 24px rgba(0,0,0,0.08),
      0 0 18px rgba(124, 58, 237, 0.035);
    font-family: var(--font-mono);
    font-size: 1.8rem;
    font-weight: 600;
    color: rgba(250, 247, 255, 0.82);
    line-height: 1;
    letter-spacing: -0.05em;
    user-select: none;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      color 0.3s ease,
      background 0.3s ease;
  }

  .step-num::before {
    content: 'Шаг';
    font-size: 0.6rem;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(215, 205, 255, 0.42);
  }

  .step-num::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(125deg, rgba(255,255,255,0.05), transparent 34%, transparent 72%, rgba(167,139,250,0.04));
    opacity: 0.44;
    pointer-events: none;
  }

  .step:hover .step-num {
    transform: translateY(-1px) scale(1.015);
    border-color: rgba(167, 139, 250, 0.14);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.04),
      0 16px 30px rgba(0,0,0,0.12),
      0 0 24px rgba(124, 58, 237, 0.06);
    color: #ffffff;
    background:
      linear-gradient(180deg, rgba(40, 30, 77, 0.2) 0%, rgba(10, 11, 24, 0.24) 100%);
  }

  .step-content {
    position: relative;
    z-index: 1;
  }

  .step-content h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.55rem;
    letter-spacing: -0.01em;
  }

  .step-content p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    font-weight: 300;
    max-width: 560px;
    line-height: 1.72;
  }

    /* ── PRICING ── */
  .pricing {
  border-top: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}

.pricing-grid {
  display: grid;
  grid-template-columns: 0.95fr 1.12fr 0.95fr;
  gap: 1.1rem;
  margin-top: 4rem;
  align-items: stretch;
  overflow: visible;
}

.price-card {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 2rem;
  min-height: 100%;
  border-radius: 24px;
  overflow: hidden;
  background: #050507;
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.03),
    0 12px 28px rgba(0, 0, 0, 0.32);
  transition:
    transform 0.25s ease,
    border-color 0.25s ease,
    box-shadow 0.25s ease;
  z-index: 1;
}

.price-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.025) 0%,
    rgba(255, 255, 255, 0.005) 100%
  );
  pointer-events: none;
}

.price-card:hover {
  transform: translateY(-4px);
  border-color: rgba(255, 255, 255, 0.12);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.04),
    0 18px 36px rgba(0, 0, 0, 0.4);
}

/* PRO */
.price-card.featured {
  background:
    radial-gradient(circle at 18% 0%, rgba(181, 149, 255, 0.18), transparent 34%),
    linear-gradient(180deg, rgba(22, 16, 40, 0.94), rgba(7, 8, 15, 0.985));
  transform: translateY(-16px) scale(1.035);
  border-color: rgba(180, 152, 255, 0.34);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.08),
    0 0 0 1px rgba(167, 139, 250, 0.08),
    0 28px 76px rgba(0, 0, 0, 0.5),
    0 0 70px rgba(124, 58, 237, 0.2),
    0 0 130px rgba(124, 58, 237, 0.14);
  backdrop-filter: blur(22px) saturate(120%);
  z-index: 3;
}

.price-card.featured::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top center, rgba(193, 170, 255, 0.12), transparent 44%),
    linear-gradient(180deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.03) 16%, rgba(255,255,255,0.01) 100%);
  pointer-events: none;
}

.price-card.featured::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -90px;
  transform: translateX(-50%);
  width: 380px;
  height: 210px;
  background: radial-gradient(circle, rgba(124, 58, 237, 0.38) 0%, transparent 72%);
  filter: blur(32px);
  pointer-events: none;
  z-index: -1;
}

.price-card.featured .price-name,
.price-card.featured .price-amount {
  color: #fff;
}

.price-card.featured .price-desc,
.price-card.featured .price-period,
.price-card.featured .price-features li {
  color: rgba(255, 255, 255, 0.84);
}

.price-card.featured .price-features {
  display: grid;
  gap: 0.62rem;
}

.price-card.featured .price-features li {
  padding: 0.82rem 0.95rem;
  border-radius: 16px;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
  border: 1px solid rgba(180, 152, 255, 0.11);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

.price-card.featured .price-features li::before {
  background: #c0a0ff;
  box-shadow: 0 0 12px rgba(192, 160, 255, 0.7);
}

.price-card.featured .price-amount {
  font-size: 2.9rem;
  text-shadow: 0 0 24px rgba(167, 139, 250, 0.18);
}

.price-tag {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  padding: 0.35rem 0.7rem;
  margin-bottom: 0.85rem;
  border-radius: 999px;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #d8ccff;
  background: rgba(167, 139, 250, 0.14);
  border: 1px solid rgba(167, 139, 250, 0.22);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
  display: none;
}

.price-card.featured .price-tag {
  display: inline-flex;
}

.price-name {
  position: relative;
  z-index: 1;
  font-size: 1.2rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.price-desc {
  position: relative;
  z-index: 1;
  font-size: 0.88rem;
  color: var(--text-tertiary);
  margin-bottom: 1.5rem;
  font-weight: 300;
  line-height: 1.5;
}

.price-amount {
  position: relative;
  z-index: 1;
  font-family: var(--font-mono);
  font-size: 2.5rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
  letter-spacing: -0.03em;
}

.price-period {
  position: relative;
  z-index: 1;
  font-size: 0.8rem;
  color: var(--text-tertiary);
  margin-bottom: 2rem;
}

.price-features {
  position: relative;
  z-index: 1;
  list-style: none;
  margin-bottom: 2rem;
  flex-grow: 1;
}

.price-features li {
  font-size: 0.875rem;
  color: var(--text-secondary);
  padding: 0.55rem 0;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-weight: 300;
}

.price-features li::before {
  content: '';
  width: 5px;
  height: 5px;
  background: var(--accent);
  border-radius: 50%;
  flex-shrink: 0;
}

.price-btn {
  position: relative;
  z-index: 1;
  width: calc(100% + 1rem);
  margin-left: -0.5rem;
  margin-right: -0.5rem;
  margin-top: auto;
  min-height: 62px;
  padding: 1rem 1.4rem;
  border-radius: 18px;
  font-size: 1.12rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  line-height: 1;
  cursor: pointer;
  text-align: center;
  text-decoration: none;
  text-transform: uppercase;
  font-family: var(--font-body);
  transition: all 0.22s ease;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background: #0a0a0e;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.04),
    0 8px 24px rgba(0,0,0,0.24);
}

.price-btn:hover {
  transform: translateY(-2px);
  border-color: rgba(255, 255, 255, 0.14);
  background: #111118;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.06),
    0 12px 28px rgba(0,0,0,0.32);
}

.price-card.featured .price-btn {
  width: calc(100% + 2rem);
  margin-left: -1rem;
  margin-right: -1rem;
  background: linear-gradient(135deg, rgba(123, 73, 255, 0.98) 0%, rgba(156, 118, 255, 0.96) 55%, rgba(189, 160, 255, 0.95) 100%);
  border-color: rgba(212, 195, 255, 0.22);
  color: #fff;
  font-size: 1.16rem;
  font-weight: 900;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  box-shadow:
    0 16px 38px rgba(124, 58, 237, 0.3),
