  .legal-strip {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .legal-strip__link,
  .legal-strip__button {
    min-height: 50px;
    padding: 0 1.45rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background:
      linear-gradient(180deg, rgba(18, 21, 35, 0.78), rgba(9, 11, 20, 0.88));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 12px 28px rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(167, 139, 250, 0.045);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    color: rgba(235, 238, 250, 0.88);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      box-shadow 160ms ease,
      color 160ms ease;
  }

  .legal-strip__button {
    font: inherit;
    cursor: pointer;
  }

  .legal-strip__link:hover,
  .legal-strip__button:hover {
    transform: translateY(-1px);
    color: #fff;
    border-color: rgba(186, 161, 255, 0.18);
    background:
      linear-gradient(180deg, rgba(24, 28, 46, 0.86), rgba(10, 12, 24, 0.92));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.07),
      0 18px 34px rgba(0, 0, 0, 0.22),
      0 0 24px rgba(127, 86, 255, 0.1);
  }

  .legal-strip__link.is-accent {
    background: linear-gradient(135deg, rgba(126, 78, 255, 0.96) 0%, rgba(156, 118, 255, 0.96) 55%, rgba(194, 163, 255, 0.94) 100%);
