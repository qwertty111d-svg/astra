  /* ── FAQ ── */
  .faq {
    border-top: 1px solid var(--border);
  }

  .faq-list {
    margin-top: 4rem;
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .faq-item {
    position: relative;
    border: 1px solid rgba(167, 139, 250, 0.075);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(12, 14, 25, 0.28) 0%, rgba(8, 10, 18, 0.16) 100%);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.025),
      0 14px 32px rgba(0,0,0,0.1);
    overflow: hidden;
  }

  .faq-item::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(circle at 100% 0%, rgba(167, 139, 250, 0.08), transparent 28%),
      linear-gradient(135deg, rgba(255,255,255,0.04), transparent 22%, transparent 78%, rgba(167,139,250,0.04));
    opacity: 0.72;
    pointer-events: none;
  }

  .faq-question {
    position: relative;
    z-index: 1;
    width: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 1.02rem;
    font-weight: 500;
    text-align: left;
    padding: 1.3rem 1.4rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    transition: color 0.2s ease;
  }

  .faq-question:hover {
    color: #ffffff;
  }

  .faq-icon {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    border: 1px solid rgba(167, 139, 250, 0.12);
    background: linear-gradient(180deg, rgba(35, 28, 63, 0.2), rgba(11, 13, 25, 0.2));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
    font-size: 1.12rem;
    color: rgba(223, 227, 244, 0.72);
    transition: transform 0.3s ease, color 0.3s ease, border-color 0.3s ease, background 0.3s ease;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-weight: 300;
  }

  .faq-item.active .faq-icon {
    transform: rotate(45deg);
    color: #ffffff;
    border-color: rgba(167, 139, 250, 0.2);
    background: linear-gradient(180deg, rgba(54, 42, 95, 0.28), rgba(11, 13, 25, 0.24));
  }

  .faq-answer {
    position: relative;
    z-index: 1;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, padding 0.35s ease;
    padding: 0 1.4rem;
  }

  .faq-item.active .faq-answer {
    max-height: 220px;
    padding-bottom: 1.3rem;
  }

  .faq-answer p {
    font-size: 0.94rem;
    color: rgba(223, 227, 244, 0.72);
    line-height: 1.76;
    font-weight: 300;
    max-width: 62ch;
  }

