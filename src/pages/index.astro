}

.price-card.featured .price-btn:hover {
  transform: translateY(-2px) scale(1.01);
  background: linear-gradient(135deg, rgba(138, 92, 255, 1) 0%, rgba(171, 133, 255, 0.98) 55%, rgba(204, 178, 255, 0.97) 100%);
  box-shadow:
    0 20px 42px rgba(124, 58, 237, 0.38),
    0 0 40px rgba(124, 58, 237, 0.24),
    inset 0 1px 0 rgba(255,255,255,0.24);
}

