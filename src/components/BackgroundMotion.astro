---
interface Props {
  overlay?: "soft" | "dark";
}

const { overlay = "soft" } = Astro.props;
---

<div class:list={{ "site-motion-bg": true, "site-motion-bg--dark": overlay === "dark" }} aria-hidden="true">
  <video
    class="site-motion-bg__video"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    disablepictureinpicture
  >
    <source src="/motion-bg.mp4" type="video/mp4" />
  </video>
  <div class="site-motion-bg__veil"></div>
  <div class="site-motion-bg__tint"></div>
</div>

<style is:global>
  .motion-page {
    position: relative;
    min-height: 100vh;
    isolation: isolate;
    overflow-x: clip;
  }

  .motion-page > :not(.site-motion-bg) {
    position: relative;
    z-index: 1;
  }

  .site-motion-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .site-motion-bg__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.08);
    opacity: 0.42;
    filter: saturate(0.95) brightness(0.52);
  }

  .site-motion-bg__veil,
  .site-motion-bg__tint {
    position: absolute;
    inset: 0;
  }

  .site-motion-bg__veil {
    background:
      radial-gradient(circle at 12% 10%, rgba(141, 99, 255, 0.15), transparent 24%),
      radial-gradient(circle at 88% 18%, rgba(102, 76, 255, 0.12), transparent 22%),
      linear-gradient(180deg, rgba(4, 5, 10, 0.58), rgba(4, 6, 12, 0.82));
  }

  .site-motion-bg__tint {
    background: linear-gradient(180deg, rgba(4, 5, 10, 0.18), rgba(4, 6, 12, 0.4));
    backdrop-filter: blur(1.5px);
  }

  .site-motion-bg--dark .site-motion-bg__video {
    opacity: 0.32;
    filter: saturate(0.88) brightness(0.44);
  }

  .site-motion-bg--dark .site-motion-bg__veil {
    background:
      radial-gradient(circle at 14% 11%, rgba(141, 99, 255, 0.12), transparent 24%),
      radial-gradient(circle at 86% 14%, rgba(103, 77, 255, 0.09), transparent 20%),
      linear-gradient(180deg, rgba(4, 5, 10, 0.72), rgba(4, 6, 12, 0.9));
  }

  @media (prefers-reduced-motion: reduce) {
    .site-motion-bg__video {
      display: none;
    }

    .site-motion-bg__veil {
      background:
        radial-gradient(circle at 14% 10%, rgba(141, 99, 255, 0.18), transparent 24%),
        radial-gradient(circle at 86% 16%, rgba(103, 77, 255, 0.12), transparent 22%),
        linear-gradient(180deg, rgba(5, 6, 11, 0.84), rgba(4, 6, 12, 0.96));
    }
  }
</style>
