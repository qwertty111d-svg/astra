---
export interface Props {
  name: "shield" | "bolt" | "sparkles" | "clock" | "empty" | "devices" | "mail";
  size?: number;
  class?: string;
}
const { name, size = 20, class: className = "" } = Astro.props;

const icons: Record<string, string> = {
  shield: `<path d="M12 3l7 3v5c0 5.25-3.4 9.28-7 10-3.6-.72-7-4.75-7-10V6l7-3Z"/><path d="M9.5 12.5l1.8 1.8 3.7-4.1"/>`,
  bolt: `<path d="M13 2 4 14h6l-1 8 9-12h-6l1-8Z"/>`,
  sparkles: `<path d="m12 3 1.7 4.3L18 9l-4.3 1.7L12 15l-1.7-4.3L6 9l4.3-1.7L12 3Z"/><path d="m19 14 .9 2.1L22 17l-2.1.9L19 20l-.9-2.1L16 17l2.1-.9L19 14Z"/><path d="m5 15 .7 1.8L7.5 18l-1.8.7L5 20.5l-.7-1.8L2.5 18l1.8-.7L5 15Z"/>`,
  clock: `<circle cx="12" cy="12" r="8"/><path d="M12 7v5l3 2"/>`,
  empty: `<path d="M6 7h12l1 2v9a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V9l1-2Z"/><path d="M9 11h6"/><path d="M9 15h4"/>`,
  devices: `<rect x="3" y="6" width="14" height="10" rx="2"/><path d="M8 18h4"/><rect x="18" y="9" width="3" height="8" rx="1"/>`,
  mail: `<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m5 8 7 5 7-5"/>`,
};
const markup = icons[name] ?? icons.sparkles;
---
<svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" class={className} set:html={markup} />
