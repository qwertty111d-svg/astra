---
import SeoHead from "../components/SeoHead.astro";
export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}
const { title = "Astra Boost", description = "Повышение FPS и оптимизация ПК.", canonical, noindex = false } = Astro.props;
---
<!doctype html>
<html lang="ru">
  <head>
    <SeoHead title={title} description={description} canonical={canonical} noindex={noindex} />
  </head>
  <body>
    <slot />
  </body>
</html>
